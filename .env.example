# =============================================================================
# API GATEWAY SMID — Plantilla de variables de entorno (DT-2)
# =============================================================================
# Copie este archivo a `.env` y complete los valores. NUNCA suba `.env` al
# repositorio (.gitignore ya lo excluye). Este archivo de ejemplo no contiene
# ningún secreto real: solo nombres y valores de referencia.
#
# Carga rápida en una shell (Linux/macOS):
#     set -a && source .env && set +a
# =============================================================================

# ----------------------------------------------------------------------------
# Puerto del Gateway (opcional; por defecto 8080).
# ----------------------------------------------------------------------------
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=local

# ----------------------------------------------------------------------------
# CONTRATO JWT (Núcleo 2.4). El Gateway VALIDA tokens; no los firma.
# ----------------------------------------------------------------------------
# Secreto HS256 de la clave VIGENTE (kid smid-2026-06 en application.yml).
# OBLIGATORIO: el Gateway no arranca sin él (fallo rápido y visible).
# Debe coincidir BYTE A BYTE con el JWT_SECRET de smid-auth.
# Genere uno fuerte (>= 256 bits) con:  openssl rand -base64 48
JWT_SECRET=

# Secreto de la clave ANTERIOR. Solo se define DURANTE una ventana de rotación,
# y exige descomentar también la línea "[smid-2026-01]" en application.yml.
# Fuera de una rotación, déjelo vacío/comentado.
# JWT_SECRET_ANTERIOR=

# Emisor y audiencia esperados en los claims iss/aud (parte del contrato 2.4).
JWT_ISSUER=smid-auth
JWT_AUDIENCE=smid-servicios

# ----------------------------------------------------------------------------
# CORS (DT-7). Lista de orígenes permitidos separada por comas, SIN espacios.
# En producción, fije los dominios reales del frontend:
#   CORS_ALLOWED_ORIGINS=https://app.defensorianinez.cl,https://admin.defensorianinez.cl
# ----------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ----------------------------------------------------------------------------
# TIMEOUTS del cliente HTTP hacia los destinos (opcionales).
#   GATEWAY_CONNECT_TIMEOUT_MS  -> conexión rechazada/DNS deriva en 503 GTW-001
#   GATEWAY_RESPONSE_TIMEOUT    -> respuesta fuera de plazo deriva en 504 GTW-002
# ----------------------------------------------------------------------------
GATEWAY_CONNECT_TIMEOUT_MS=5000
GATEWAY_RESPONSE_TIMEOUT=30s

# ----------------------------------------------------------------------------
# DESTINOS (URIs internas de los microservicios). En local apuntan a loopback;
# en producción, a los nombres de servicio del orquestador / DNS interno.
# ----------------------------------------------------------------------------
# --- Núcleo Fundacional SMID ---
AUTH_SERVICE_URL=http://localhost:8081
CATALOGO_SERVICE_URL=http://localhost:8087
PERSONAS_SERVICE_URL=http://localhost:8088
REQUERIMIENTOS_SERVICE_URL=http://localhost:8089
CASOS_SERVICE_URL=http://localhost:8090
VULNERACIONES_SERVICE_URL=http://localhost:8091
PRODUCTOS_SERVICE_URL=http://localhost:8092

# --- Legados (patrón strangler) ---
SIGER_SERVICE_URL=http://localhost:8082
SGS_SERVICE_URL=http://localhost:8083
PRONINEZ_SERVICE_URL=http://localhost:8084
SMID_SERVICE_URL=http://localhost:8085
ESNNA_SERVICE_URL=http://localhost:8086
